pe: AWS::Events::Rule\n      Properties:\n        Name: pp-kitchen-order-created-rule\n        EventBusName: pp-bus\n        EventPattern:\n          source:\n            - pp.orders\n          detail-type:\n            - order.created\n        State: ENABLED\n        Targets:\n          - Id: IniciarWorkflowTarget\n            Arn: !GetAtt IniciarWorkflowLambdaFunction.Arn\n\n    OrderCreatedRulePermission:\n      Type: AWS::Lambda::Permission\n      Properties:\n        FunctionName: !GetAtt IniciarWorkflowLambdaFunction.Arn\n        Action: lambda:InvokeFunction\n        Principal: events.amazonaws.com\n        SourceArn: !GetAtt OrderCreatedRule.Arn\n",
