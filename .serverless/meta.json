{
  "/home/ubuntu/pp-kitchen/serverless.yml": {
    "versionFramework": "4.39.0",
    "servicePath": "/home/ubuntu/pp-kitchen/serverless.yml",
    "serviceConfigFileName": "serverless.yml",
    "service": {
      "service": "pp-kitchen",
      "provider": {
        "name": "aws",
        "runtime": "python3.12",
        "region": "us-east-1",
        "iam": {
          "role": "arn:aws:iam::${aws:accountId}:role/LabRole"
        },
        "environment": {
          "TASKS_TABLE": "pp-tasks",
          "EVENT_BUS_NAME": "${ssm:/pp/eventBusName}"
        }
      },
      "plugins": [
        "serverless-step-functions"
      ],
      "custom": {
        "stateMachineName": "pp-kitchen-sm"
      },
      "functions": {
        "registrar": {
          "handler": "functions/registrar.handler"
        },
        "completar": {
          "handler": "functions/completar.handler",
          "events": [
            {
              "http": {
                "path": "tasks/completar",
                "method": "post",
                "cors": true
              }
            }
          ]
        },
        "listarPendientes": {
          "handler": "functions/listar_pendientes.handler",
          "events": [
            {
              "http": {
                "path": "tasks/pendientes",
                "method": "get",
                "cors": true
              }
            }
          ]
        },
        "emitirStepCompleted": {
          "handler": "functions/emitir_step_completed.handler"
        },
        "iniciarWorkflow": {
          "handler": "functions/iniciar_workflow.handler",
          "environment": {
            "STATE_MACHINE_ARN": {
              "Fn::Sub": "arn:aws:states:${AWS::Region}:${AWS::AccountId}:stateMachine:pp-kitchen-sm"
            }
          }
        }
      },
      "stepFunctions": {
        "stateMachines": {
          "kitchenWorkflow": {
            "name": "pp-kitchen-sm",
            "role": "arn:aws:iam::${aws:accountId}:role/LabRole",
            "definition": {
              "Comment": "pp-kitchen v3 — workflow enriquecido con Choice, Parallel, Wait, Retry, Catch",
              "StartAt": "ValidarPedido",
              "States": {
                "ValidarPedido": {
                  "Type": "Choice",
                  "Choices": [
                    {
                      "Variable": "$.orderId",
                      "IsPresent": true,
                      "Next": "RegistrarRecepcion"
                    }
                  ],
                  "Default": "PedidoInvalido"
                },
                "PedidoInvalido": {
                  "Type": "Fail",
                  "Error": "PedidoInvalido",
                  "Cause": "El pedido no tiene orderId"
                },
                "RegistrarRecepcion": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "EmitirStepCompletedLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "RECIBIDO"
                    }
                  },
                  "ResultPath": null,
                  "Retry": [
                    {
                      "ErrorEquals": [
                        "Lambda.ServiceException",
                        "Lambda.AWSLambdaException"
                      ],
                      "IntervalSeconds": 2,
                      "MaxAttempts": 3,
                      "BackoffRate": 2
                    }
                  ],
                  "Catch": [
                    {
                      "ErrorEquals": [
                        "States.ALL"
                      ],
                      "Next": "ErrorGeneral",
                      "ResultPath": "$.error"
                    }
                  ],
                  "Next": "PreparacionParalela"
                },
                "PreparacionParalela": {
                  "Type": "Parallel",
                  "Branches": [
                    {
                      "StartAt": "NotificarCocina",
                      "States": {
                        "NotificarCocina": {
                          "Type": "Wait",
                          "Seconds": 2,
                          "Next": "CocinaLista"
                        },
                        "CocinaLista": {
                          "Type": "Pass",
                          "Result": {
                            "preparacion": "cocina_lista"
                          },
                          "End": true
                        }
                      }
                    },
                    {
                      "StartAt": "NotificarAlmacen",
                      "States": {
                        "NotificarAlmacen": {
                          "Type": "Wait",
                          "Seconds": 1,
                          "Next": "AlmacenListo"
                        },
                        "AlmacenListo": {
                          "Type": "Pass",
                          "Result": {
                            "preparacion": "almacen_listo"
                          },
                          "End": true
                        }
                      }
                    }
                  ],
                  "ResultPath": null,
                  "Next": "EN_COCINA"
                },
                "EN_COCINA": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke.waitForTaskToken",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "RegistrarLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "EN_COCINA",
                      "workerId.$": "$.workerId",
                      "taskToken.$": "<REDACTED>"
                    }
                  },
                  "ResultPath": null,
                  "Retry": [
                    {
                      "ErrorEquals": [
                        "Lambda.ServiceException"
                      ],
                      "IntervalSeconds": 2,
                      "MaxAttempts": 2,
                      "BackoffRate": 2
                    }
                  ],
                  "Catch": [
                    {
                      "ErrorEquals": [
                        "States.HeartbeatTimeout"
                      ],
                      "Next": "TimeoutCocina",
                      "ResultPath": "$.error"
                    },
                    {
                      "ErrorEquals": [
                        "States.ALL"
                      ],
                      "Next": "ErrorGeneral",
                      "ResultPath": "$.error"
                    }
                  ],
                  "HeartbeatSeconds": 3600,
                  "Next": "EmitirCocinaCompleta"
                },
                "TimeoutCocina": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "EmitirStepCompletedLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "TIMEOUT_COCINA"
                    }
                  },
                  "ResultPath": null,
                  "Next": "EN_COCINA"
                },
                "EmitirCocinaCompleta": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "EmitirStepCompletedLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "EN_COCINA"
                    }
                  },
                  "ResultPath": null,
                  "Retry": [
                    {
                      "ErrorEquals": [
                        "States.ALL"
                      ],
                      "IntervalSeconds": 2,
                      "MaxAttempts": 3,
                      "BackoffRate": 2
                    }
                  ],
                  "Catch": [
                    {
                      "ErrorEquals": [
                        "States.ALL"
                      ],
                      "Next": "ErrorGeneral",
                      "ResultPath": "$.error"
                    }
                  ],
                  "Next": "VerificarStockDespacho"
                },
                "VerificarStockDespacho": {
                  "Type": "Choice",
                  "Choices": [
                    {
                      "Variable": "$.workerId",
                      "IsPresent": true,
                      "Next": "EN_DESPACHO"
                    }
                  ],
                  "Default": "AsignarWorkerDefault"
                },
                "AsignarWorkerDefault": {
                  "Type": "Pass",
                  "Result": {
                    "workerId": "worker-default"
                  },
                  "ResultPath": "$.workerAsignado",
                  "Next": "EN_DESPACHO"
                },
                "EN_DESPACHO": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke.waitForTaskToken",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "RegistrarLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "EN_DESPACHO",
                      "workerId.$": "$.workerId",
                      "taskToken.$": "<REDACTED>"
                    }
                  },
                  "ResultPath": null,
                  "Retry": [
                    {
                      "ErrorEquals": [
                        "Lambda.ServiceException"
                      ],
                      "IntervalSeconds": 2,
                      "MaxAttempts": 2,
                      "BackoffRate": 2
                    }
                  ],
                  "Catch": [
                    {
                      "ErrorEquals": [
                        "States.HeartbeatTimeout"
                      ],
                      "Next": "TimeoutDespacho",
                      "ResultPath": "$.error"
                    },
                    {
                      "ErrorEquals": [
                        "States.ALL"
                      ],
                      "Next": "ErrorGeneral",
                      "ResultPath": "$.error"
                    }
                  ],
                  "HeartbeatSeconds": 3600,
                  "Next": "EmitirDespachoCompleto"
                },
                "TimeoutDespacho": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "EmitirStepCompletedLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "TIMEOUT_DESPACHO"
                    }
                  },
                  "ResultPath": null,
                  "Next": "EN_DESPACHO"
                },
                "EmitirDespachoCompleto": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "EmitirStepCompletedLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "EN_DESPACHO"
                    }
                  },
                  "ResultPath": null,
                  "Retry": [
                    {
                      "ErrorEquals": [
                        "States.ALL"
                      ],
                      "IntervalSeconds": 2,
                      "MaxAttempts": 3,
                      "BackoffRate": 2
                    }
                  ],
                  "Catch": [
                    {
                      "ErrorEquals": [
                        "States.ALL"
                      ],
                      "Next": "ErrorGeneral",
                      "ResultPath": "$.error"
                    }
                  ],
                  "Next": "EN_REPARTO"
                },
                "EN_REPARTO": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke.waitForTaskToken",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "RegistrarLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "EN_REPARTO",
                      "workerId.$": "$.workerId",
                      "taskToken.$": "<REDACTED>"
                    }
                  },
                  "ResultPath": null,
                  "Retry": [
                    {
                      "ErrorEquals": [
                        "Lambda.ServiceException"
                      ],
                      "IntervalSeconds": 2,
                      "MaxAttempts": 2,
                      "BackoffRate": 2
                    }
                  ],
                  "Catch": [
                    {
                      "ErrorEquals": [
                        "States.HeartbeatTimeout"
                      ],
                      "Next": "TimeoutReparto",
                      "ResultPath": "$.error"
                    },
                    {
                      "ErrorEquals": [
                        "States.ALL"
                      ],
                      "Next": "ErrorGeneral",
                      "ResultPath": "$.error"
                    }
                  ],
                  "HeartbeatSeconds": 7200,
                  "Next": "EmitirRepartoCompleto"
                },
                "TimeoutReparto": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "EmitirStepCompletedLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "TIMEOUT_REPARTO"
                    }
                  },
                  "ResultPath": null,
                  "Next": "EN_REPARTO"
                },
                "EmitirRepartoCompleto": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "EmitirStepCompletedLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "EN_REPARTO"
                    }
                  },
                  "ResultPath": null,
                  "Next": "FinalizarEntrega"
                },
                "FinalizarEntrega": {
                  "Type": "Parallel",
                  "Branches": [
                    {
                      "StartAt": "RegistrarEntrega",
                      "States": {
                        "RegistrarEntrega": {
                          "Type": "Task",
                          "Resource": "arn:aws:states:::lambda:invoke",
                          "Parameters": {
                            "FunctionName": {
                              "Fn::GetAtt": [
                                "EmitirStepCompletedLambdaFunction",
                                "Arn"
                              ]
                            },
                            "Payload": {
                              "orderId.$": "$.orderId",
                              "tenantId.$": "$.tenantId",
                              "estado": "ENTREGADO"
                            }
                          },
                          "ResultPath": null,
                          "End": true
                        }
                      }
                    },
                    {
                      "StartAt": "EsperarConfirmacion",
                      "States": {
                        "EsperarConfirmacion": {
                          "Type": "Wait",
                          "Seconds": 3,
                          "Next": "EntregaConfirmada"
                        },
                        "EntregaConfirmada": {
                          "Type": "Pass",
                          "Result": {
                            "confirmacion": "ok"
                          },
                          "End": true
                        }
                      }
                    }
                  ],
                  "ResultPath": null,
                  "Next": "ENTREGADO"
                },
                "ENTREGADO": {
                  "Type": "Succeed"
                },
                "ErrorGeneral": {
                  "Type": "Task",
                  "Resource": "arn:aws:states:::lambda:invoke",
                  "Parameters": {
                    "FunctionName": {
                      "Fn::GetAtt": [
                        "EmitirStepCompletedLambdaFunction",
                        "Arn"
                      ]
                    },
                    "Payload": {
                      "orderId.$": "$.orderId",
                      "tenantId.$": "$.tenantId",
                      "estado": "ERROR"
                    }
                  },
                  "ResultPath": null,
                  "Next": "FalloCritico"
                },
                "FalloCritico": {
                  "Type": "Fail",
                  "Error": "ErrorCritico",
                  "Cause": "El workflow encontró un error irrecuperable"
                }
              }
            }
          }
        }
      },
      "resources": {
        "Resources": {
          "TasksTable": {
            "Type": "AWS::DynamoDB::Table",
            "Properties": {
              "TableName": "pp-tasks",
              "BillingMode": "PAY_PER_REQUEST",
              "AttributeDefinitions": [
                {
                  "AttributeName": "orderId",
                  "AttributeType": "S"
                },
                {
                  "AttributeName": "estado",
                  "AttributeType": "S"
                }
              ],
              "KeySchema": [
                {
                  "AttributeName": "orderId",
                  "KeyType": "HASH"
                },
                {
                  "AttributeName": "estado",
                  "KeyType": "RANGE"
                }
              ]
            }
          },
          "KitchenSMParam": {
            "Type": "AWS::SSM::Parameter",
            "Properties": {
              "Name": "/pp/kitchen-sm-arn",
              "Type": "String",
              "Value": {
                "Fn::Sub": "arn:aws:states:${AWS::Region}:${AWS::AccountId}:stateMachine:pp-kitchen-sm"
              }
            }
          },
          "OrderCreatedRule": {
            "Type": "AWS::Events::Rule",
            "Properties": {
              "Name": "pp-kitchen-order-created-rule",
              "EventBusName": "pp-bus",
              "EventPattern": {
                "source": [
                  "pp.orders"
                ],
                "detail-type": [
                  "order.created"
                ]
              },
              "State": "ENABLED",
              "Targets": [
                {
                  "Id": "IniciarWorkflowTarget",
                  "Arn": {
                    "Fn::GetAtt": [
                      "IniciarWorkflowLambdaFunction",
                      "Arn"
                    ]
                  }
                }
              ]
            }
          },
          "OrderCreatedRulePermission": {
            "Type": "AWS::Lambda::Permission",
            "Properties": {
              "FunctionName": {
                "Fn::GetAtt": [
                  "IniciarWorkflowLambdaFunction",
                  "Arn"
                ]
              },
              "Action": "lambda:InvokeFunction",
              "Principal": "events.amazonaws.com",
              "SourceArn": {
                "Fn::GetAtt": [
                  "OrderCreatedRule",
                  "Arn"
                ]
              }
            }
          }
        }
      }
    },
    "provider": {
